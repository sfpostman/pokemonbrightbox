{
  "endpoints": {
    "/books": {
      "get": "e2e-library books fetch-a-list-of-books --x-mock-response-code \"500\" --accept \"application/json\"\n",
      "post": "e2e-library books create-a-new-book --x-mock-response-code \"201\" --x-mock-response-name \"Dynamic Variables Mock Demo\" --accept \"application/json\" --body '{\"title\":\"{{tempBookTitle}}\",\"author\":\"{{$randomFirstName}} {{$randomLastName}}\",\"genre\":\"fiction\",\"yearPublished\":\"1967\"}'\n"
    },
    "/books/{id}": {
      "get": "e2e-library books verify-the-book-exists --id \"id\" --x-mock-response-code \"200\" --accept \"application/json\"\n",
      "patch": "e2e-library books checkout-new-book --id \"id\" --x-mock-response-code \"200\" --accept \"application/json\" --body '{\"checkedOut\":true}'\n"
    }
  },
  "example": "e2e-library books fetch-a-list-of-books --x-mock-response-code \"500\" --accept \"application/json\"\n",
  "authentication": {
    "apiKey": {
      "constructor": "export E2E_LIBRARY_API_KEY=\"YOUR-API-KEY\"\ne2e-library <command>",
      "setter": "e2e-library config set api_key \"YOUR-API-KEY\""
    }
  }
}
